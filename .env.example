# Meadow HubSpot Webhook Handler - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it should be in .gitignore

# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# HubSpot API Configuration
HUBSPOT_API_KEY=your-hubspot-api-key-here
HUBSPOT_API_ENDPOINT=https://api.hubapi.com

# Database Configuration (optional - if using PostgreSQL for deduplication)
DATABASE_URL=postgresql://user:password@host:port/database

# Lambda Configuration
LAMBDA_FUNCTION=meadow-hubspot-webhook-handler
ECR_IMAGE_NAME=meadow-hubspot-webhook-handler

# Application Settings
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOCAL=True  # Set to True for local testing

# Webhook Security (Stage 2+)
WEBHOOK_SECRET=your-webhook-signature-secret-here

# Feature Flags (optional)
ENABLE_IDEMPOTENCY_CHECK=true
ENABLE_RETRY_QUEUE=true
